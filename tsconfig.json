{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        // "moduleResolution": "node",

        "allowImportingTsExtensions": true,
        "noEmit": false,
        "rewriteRelativeImportExtensions": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "sourceMap": true,
        "inlineSources": true,
        "declaration": true,
        "types": ["node"]
    }
}
